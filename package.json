{
  "name": "teesim",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-based 3D TEE simulator for cardiology education",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "spike:tee": "vite --config spike/pseudo-tee/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/g960059/TeeSim.git"
  },
  "license": "MIT",
  "dependencies": {
    "@kitware/vtk.js": "^35.5.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
